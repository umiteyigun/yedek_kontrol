# Image release updater ayarlari
RELEASE_UPDATER_ENABLED=0
YEDEK_ROOT=/opt/yedek_kontrol

# Takip modu: latest = hub/registry'den otomatik tag | pin = RELEASE_TARGET_TAG sabit
RELEASE_TRACK=latest

# pin modunda veya manifest/registry okunamazsa kullanilan sabit tag
RELEASE_TARGET_TAG=

# Public manifesto (Hub) — OneDev raw kullanmayin (login HTML doner)
RELEASE_MANIFEST_URL=https://centos.trtekyazilim.com:8444/release/latest.env
# 2. deneme (opsiyonel; RELEASE_MANIFEST_URL ile ayniysa atlanir)
HUB_MANIFEST_URL=https://centos.trtekyazilim.com:8444/release/latest.env

# Registry
RELEASE_REGISTRY_HOST=git.trtek.tr
RELEASE_REGISTRY_USER=oauth2

# Client tarafi sadece readonly token kullanir
RELEASE_READONLY_TOKEN=

# Image adlari
RELEASE_CORE_IMAGE=git.trtek.tr/umiteyigun/yedek_kontrol/yedek-core
RELEASE_AGENT_IMAGE=git.trtek.tr/umiteyigun/yedek_kontrol/yedek-central-agent

# Dev/local test icin pull atla (0/1)
RELEASE_SKIP_PULL=0
