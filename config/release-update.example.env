# Image release updater ayarlari
RELEASE_UPDATER_ENABLED=0
YEDEK_ROOT=/opt/yedek_kontrol

# Takip modu: latest = registry/manifest'ten otomatik tag | pin = RELEASE_TARGET_TAG sabit
RELEASE_TRACK=latest

# pin modunda veya manifest okunamazsa kullanilan sabit tag
RELEASE_TARGET_TAG=

# Registry
RELEASE_REGISTRY_HOST=git.trtek.tr
RELEASE_REGISTRY_USER=oauth2

# Client tarafi sadece readonly token kullanir
RELEASE_READONLY_TOKEN=

# Image adlari
RELEASE_CORE_IMAGE=git.trtek.tr/umiteyigun/yedek_kontrol/yedek-core
RELEASE_AGENT_IMAGE=git.trtek.tr/umiteyigun/yedek_kontrol/yedek-central-agent

# Dev/local test icin pull atla (0/1)
RELEASE_SKIP_PULL=0
