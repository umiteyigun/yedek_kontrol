# /yedek/config/auto-update.env — kurum sunucusunda (repoda degil)
# git.trtek.tr main commit'lerini sessizce kontrol eder; degisiklik varsa deploy eder.

AUTO_UPDATE_ENABLED=1
AUTO_UPDATE_BRANCH=main
AUTO_UPDATE_REPO_URL=https://git.trtek.tr/umiteyigun/yedek_kontrol.git

# git.trtek.tr (Gitea) veya GitHub private repo icin:
# AUTO_UPDATE_GIT_TOKEN=...

# YEDEK_ROOT bos birakilirsa /opt/yedek_kontrol veya setup sirasinda belirlenen yol kullanilir
# YEDEK_ROOT=/opt/yedek_kontrol
