# Merkez hub baglantisi — kurum sunucusunda (yedek-docker ile birlikte)
# Kurulum: ORG_ENROLLMENT_CODE ve HUB_HTTP_URL doldurun, setup.sh agent'i baslatir
ORG_ENROLLMENT_CODE=
HUB_HTTP_URL=https://MERKEZ_IP:8444
HUB_WS_URL=wss://MERKEZ_IP:8444/agent/v1
PANEL_LOCAL_URL=https://127.0.0.1:8443
NODE_LABEL=primary
NODE_ROLE=PRIMARY
AGENT_VERIFY_TLS=0
AGENT_STATE_DIR=/var/lib/yedek-agent
# Hub ile ayni deger (yedek-core panel merkez proxy SSO)
CENTRAL_PROXY_SECRET=
