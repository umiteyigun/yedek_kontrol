# Merkez hub baglantisi — kurum sunucusunda (/yedek/config/central-agent.env)
# Kurulum: bash setup.sh (interaktif) veya asagiyi elle doldurun.
#
# ── ORG_ENROLLMENT_CODE ─────────────────────────────────────────────────────
# Kuruma ozel kayit kodu. Hub'da "Kurum ekle" yapilinca uretilir / verilir.
# Ornek: SAKARYA-ADS-2024, USKUDAR-DB-01
# Nereden: Merkez yonetici -> hub paneli -> Kurumlar -> enrollment_code
# Ayni kurumun tum sunuculari AYNI kodu kullanir (NODE_* farkli olur).
#
ORG_ENROLLMENT_CODE=
#
# ── HUB_HTTP_URL / HUB_WS_URL ───────────────────────────────────────────────
# Merkez hub'un disaridan erisilen HTTPS adresi (agent kayit + WS tuneli).
# Ornek HTTP:  https://10.0.0.5:8444
#              https://yedek-hub.sirket.local:8444
# WS genelde otomatik: wss://ADRES:8444/agent/v1
#
HUB_HTTP_URL=https://MERKEZ_IP:8444
HUB_WS_URL=wss://MERKEZ_IP:8444/agent/v1
#
# Bu sunucudaki yerel panel (nginx HTTPS) — genelde degistirmeyin.
PANEL_LOCAL_URL=https://127.0.0.1:8443
#
# ── NODE_LABEL / NODE_ROLE ──────────────────────────────────────────────────
# Hub'da bu sunucuyu ayirt etmek icin. Tek sunucu: primary + PRIMARY
# DataGuard / ikinci node: standby + STANDBY veya dg2 + STANDBY
#
NODE_LABEL=primary
NODE_ROLE=PRIMARY
#
AGENT_VERIFY_TLS=0
AGENT_STATE_DIR=/var/lib/yedek-agent
#
# ── HUB_AGENT_REGISTER_SECRET ───────────────────────────────────────────────
# Hub'daki HUB_AGENT_REGISTER_SECRET ile BIREBIR ayni (ilk agent kaydi icin).
# Ornek: 9d45282e82691e7131af7a6c5a51af8dce30b05045519ea567f7cbde64bcad5b
# Nereden: merkez sunucu -> /root/yedek_central/config/hub.dev.env (veya prod .env)
#
HUB_AGENT_REGISTER_SECRET=
#
# ── CENTRAL_PROXY_SECRET ─────────────────────────────────────────────────────
# Hub'daki HUB_CENTRAL_PROXY_SECRET ile BIREBIR ayni (min 32 karakter).
# Merkez panelden bu kurumun paneline SSO/proxy acilinca imza dogrulamasi icin.
# Ornek: 1d549a1f5096164bea93376c095c7a79c38ff72e1ad60df0e860eb58ae09a809
# Nereden: merkez sunucu -> /root/yedek_central/config/hub.dev.env
#
CENTRAL_PROXY_SECRET=
